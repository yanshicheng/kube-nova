syntax = "v1"

info(
    title: "DevOps Pipeline Config API"
    desc: "DevOps 流水线配置接口"
    author: "Yan Shicheng"
    email: "ikubeops@gmail.com"
    version: "1.0"
)

import "./base.api"

type (
    StepParamOption {
        Label string `json:"label"`
        Value string `json:"value"`
    }

    CompoundParamField {
        Name string `json:"name" validate:"required,min=1,max=128"`
        Code string `json:"code" validate:"required,min=1,max=128"`
        DefaultValue string `json:"defaultValue,optional" validate:"omitempty"`
        ParamType string `json:"paramType" validate:"required,max=128"`
        Mode string `json:"mode" validate:"required,oneof=env paas"`
        Required bool `json:"required,optional"`
        Readonly bool `json:"readonly,optional"`
        Description string `json:"description,optional" validate:"omitempty,max=512"`
        SelectList []StepParamOption `json:"selectList,optional"`
        AllowCustom bool `json:"allowCustom,optional"`
        RuntimeMode string `json:"runtimeMode,optional" validate:"omitempty,oneof=env"`
        Config StepParamConfig `json:"config,optional"`
    }

    StepParamConfig {
        Options []StepParamOption `json:"options,optional"`
        ChannelGroupCode string `json:"channelGroupCode,optional" validate:"omitempty,max=64"`
        ChannelTypeFilter string `json:"channelTypeFilter,optional" validate:"omitempty,max=64"`
        ChannelParamCode string `json:"channelParamCode,optional" validate:"omitempty,max=128"`
        ChannelBindingId string `json:"channelBindingId,optional" validate:"omitempty"`
        MappingField string `json:"mappingField,optional" validate:"omitempty,max=128"`
        VoucherModel string `json:"voucherModel,optional" validate:"omitempty,max=64"`
        CredentialId string `json:"credentialId,optional" validate:"omitempty"`
        CredentialMode string `json:"credentialMode,optional" validate:"omitempty,oneof=field jsonData jsonBase64 jenkinsCredentialId"`
        CredentialSourceParamCode string `json:"credentialSourceParamCode,optional" validate:"omitempty,max=128"`
        ProjectParamCode string `json:"projectParamCode,optional" validate:"omitempty,max=128"`
        ComponentParamCode string `json:"componentParamCode,optional" validate:"omitempty,max=128"`
        Provider string `json:"provider,optional" validate:"omitempty,max=64"`
        ValidateRemote bool `json:"validateRemote,optional"`
        CompoundFields []CompoundParamField `json:"compoundFields,optional"`
        FullRow bool `json:"fullRow,optional"`
        RenderMode string `json:"renderMode,optional" validate:"omitempty,oneof=normal inventory"`
        ConfigTypeId string `json:"configTypeId,optional" validate:"omitempty"`
        ConfigTypeCode string `json:"configTypeCode,optional" validate:"omitempty,max=64"`
        ValueMode string `json:"valueMode,optional" validate:"omitempty,oneof=string text credentialsSecretFile base64"`
        DependencyParamCodes []StepParamDependency `json:"dependencyParamCodes,optional"`
    }

    StepParamDependency {
        Field string `json:"field"`
        ParamCode string `json:"paramCode"`
    }

    StepArtifactConfig {
        Enabled bool `json:"enabled,optional"`
        Type string `json:"type,optional" validate:"omitempty,oneof=report artifact"`
        Name string `json:"name,optional" validate:"omitempty,max=128"`
        Path string `json:"path,optional" validate:"omitempty,max=512"`
        Required bool `json:"required,optional"`
        ContentType string `json:"contentType,optional" validate:"omitempty,max=128"`
    }

    DevopsStepParam {
        Name string `json:"name" validate:"required,min=1,max=128"`
        Code string `json:"code" validate:"required,min=1,max=128"`
        DefaultValue string `json:"defaultValue,optional" validate:"omitempty"`
        ParamType string `json:"paramType" validate:"required,max=128"`
        Mode string `json:"mode" validate:"required,oneof=params env paas"`
        Required bool `json:"required,optional"`
        Readonly bool `json:"readonly,optional"`
        Description string `json:"description,optional" validate:"omitempty,max=512"`
        SelectList []StepParamOption `json:"selectList,optional"`
        AllowCustom bool `json:"allowCustom,optional"`
        ChannelGroupCode string `json:"channelGroupCode,optional" validate:"omitempty,max=64"`
        MappingField string `json:"mappingField,optional" validate:"omitempty,max=64"`
        VoucherModel string `json:"voucherModel,optional" validate:"omitempty,max=64"`
        SortOrder int64 `json:"sortOrder,optional" default:"0" validate:"gte=0"`
        RuntimeMode string `json:"runtimeMode,optional" validate:"omitempty,oneof=params env"`
        RuntimeConfig bool `json:"runtimeConfig,optional"`
        Config StepParamConfig `json:"config,optional"`
    }

    TektonPropertySpec {
        Type string `json:"type,optional" validate:"omitempty,oneof=string array object"`
    }

    DevopsTektonTaskParam {
        Name string `json:"name" validate:"required,min=1,max=128"`
        Type string `json:"type,optional" default:"string" validate:"omitempty,oneof=string array object"`
        DefaultValue string `json:"defaultValue,optional" validate:"omitempty"`
        Description string `json:"description,optional" validate:"omitempty,max=512"`
        Enum []string `json:"enum,optional"`
        Properties map[string]TektonPropertySpec `json:"properties,optional"`
        Required bool `json:"required,optional"`
    }

    DevopsTektonTaskResult {
        Name string `json:"name" validate:"required,min=1,max=128"`
        Type string `json:"type,optional" default:"string" validate:"omitempty,oneof=string array object"`
        Description string `json:"description,optional" validate:"omitempty,max=512"`
        Value string `json:"value,optional" validate:"omitempty"`
        Properties map[string]TektonPropertySpec `json:"properties,optional"`
    }

    DevopsTektonWorkspace {
        Name string `json:"name" validate:"required,min=1,max=128"`
        Description string `json:"description,optional" validate:"omitempty,max=512"`
        Optional bool `json:"optional,optional"`
        ReadOnly bool `json:"readOnly,optional"`
        MountPath string `json:"mountPath,optional" validate:"omitempty,max=256"`
    }

    DevopsStepCategory {
        Id string `json:"id"`
        Name string `json:"name"`
        Code string `json:"code"`
        Description string `json:"description"`
        Icon string `json:"icon"`
        IconColor string `json:"iconColor"`
        SortOrder int64 `json:"sortOrder"`
        Status int64 `json:"status"`
        CreatedBy string `json:"createdBy"`
        UpdatedBy string `json:"updatedBy"`
        CreatedAt int64 `json:"createdAt"`
        UpdatedAt int64 `json:"updatedAt"`
    }

    CreateDevopsStepCategoryRequest {
        Name string `json:"name" validate:"required,min=1,max=128"`
        Code string `json:"code" validate:"required,min=2,max=64"`
        Description string `json:"description,optional" validate:"omitempty,max=512"`
        Icon string `json:"icon,optional" validate:"omitempty,max=128"`
        IconColor string `json:"iconColor,optional" validate:"omitempty,max=32"`
        SortOrder int64 `json:"sortOrder,optional" default:"0" validate:"gte=0"`
        Status int64 `json:"status,optional" default:"1" validate:"oneof=0 1"`
    }

    UpdateDevopsStepCategoryRequest {
        Id string `path:"id" validate:"required"`
        Name string `json:"name" validate:"required,min=1,max=128"`
        Description string `json:"description,optional" validate:"omitempty,max=512"`
        Icon string `json:"icon,optional" validate:"omitempty,max=128"`
        IconColor string `json:"iconColor,optional" validate:"omitempty,max=32"`
        SortOrder int64 `json:"sortOrder,optional" default:"0" validate:"gte=0"`
        Status int64 `json:"status,optional" default:"1" validate:"oneof=0 1"`
    }

    ListDevopsStepCategoryRequest {
        Page uint64 `form:"page,optional" default:"1" validate:"required,min=1"`
        PageSize uint64 `form:"pageSize,optional" default:"20" validate:"required,min=1,max=200"`
        Name string `form:"name,optional" validate:"omitempty,max=128"`
        Code string `form:"code,optional" validate:"omitempty,max=64"`
        Status int64 `form:"status,optional" default:"-1" validate:"oneof=-1 0 1"`
    }

    ListDevopsStepCategoryResponse {
        Items []DevopsStepCategory `json:"items"`
        Total uint64 `json:"total"`
    }

    DevopsStepTemplate {
        Id string `json:"id"`
        Name string `json:"name"`
        Code string `json:"code"`
        Icon string `json:"icon"`
        IconColor string `json:"iconColor"`
        Description string `json:"description"`
        Type string `json:"type"`
        CategoryId string `json:"categoryId"`
        CategoryName string `json:"categoryName"`
        EngineType string `json:"engineType"`
        EngineChannelGroupCode string `json:"engineChannelGroupCode"`
        EngineChannelType string `json:"engineChannelType"`
        StageContent string `json:"stageContent"`
        Params []DevopsStepParam `json:"params"`
        TaskParams []DevopsTektonTaskParam `json:"taskParams"`
        TaskResults []DevopsTektonTaskResult `json:"taskResults"`
        TaskWorkspaces []DevopsTektonWorkspace `json:"taskWorkspaces"`
        ArtifactConfig StepArtifactConfig `json:"artifactConfig"`
        Status int64 `json:"status"`
        CreatedBy string `json:"createdBy"`
        UpdatedBy string `json:"updatedBy"`
        CreatedAt int64 `json:"createdAt"`
        UpdatedAt int64 `json:"updatedAt"`
    }

    CreateDevopsStepTemplateRequest {
        Name string `json:"name" validate:"required,min=1,max=128"`
        Code string `json:"code" validate:"required,min=2,max=64"`
        Icon string `json:"icon,optional" validate:"omitempty,max=128"`
        IconColor string `json:"iconColor,optional" validate:"omitempty,max=32"`
        Description string `json:"description,optional" validate:"omitempty,max=512"`
        Type string `json:"type,optional" default:"task" validate:"oneof=task manual_approval"`
        CategoryId string `json:"categoryId" validate:"required"`
        StageContent string `json:"stageContent" validate:"required,min=1"`
        Params []DevopsStepParam `json:"params,optional"`
        TaskParams []DevopsTektonTaskParam `json:"taskParams,optional"`
        TaskResults []DevopsTektonTaskResult `json:"taskResults,optional"`
        TaskWorkspaces []DevopsTektonWorkspace `json:"taskWorkspaces,optional"`
        ArtifactConfig StepArtifactConfig `json:"artifactConfig,optional"`
        Status int64 `json:"status,optional" default:"1" validate:"oneof=0 1"`
    }

    UpdateDevopsStepTemplateRequest {
        Id string `path:"id" validate:"required"`
        Name string `json:"name" validate:"required,min=1,max=128"`
        Icon string `json:"icon,optional" validate:"omitempty,max=128"`
        IconColor string `json:"iconColor,optional" validate:"omitempty,max=32"`
        Description string `json:"description,optional" validate:"omitempty,max=512"`
        Type string `json:"type,optional" default:"task" validate:"oneof=task manual_approval"`
        CategoryId string `json:"categoryId" validate:"required"`
        StageContent string `json:"stageContent" validate:"required,min=1"`
        Params []DevopsStepParam `json:"params,optional"`
        TaskParams []DevopsTektonTaskParam `json:"taskParams,optional"`
        TaskResults []DevopsTektonTaskResult `json:"taskResults,optional"`
        TaskWorkspaces []DevopsTektonWorkspace `json:"taskWorkspaces,optional"`
        ArtifactConfig StepArtifactConfig `json:"artifactConfig,optional"`
        Status int64 `json:"status,optional" default:"1" validate:"oneof=0 1"`
    }

    UpdateStatusRequest {
        Id string `path:"id" validate:"required"`
        Status int64 `json:"status" validate:"oneof=0 1"`
    }

    ListDevopsStepTemplateRequest {
        Page uint64 `form:"page,optional" default:"1" validate:"required,min=1"`
        PageSize uint64 `form:"pageSize,optional" default:"12" validate:"required,min=1,max=200"`
        Name string `form:"name,optional" validate:"omitempty,max=128"`
        Code string `form:"code,optional" validate:"omitempty,max=64"`
        CategoryId string `form:"categoryId,optional" validate:"omitempty"`
        EngineType string `form:"engineType,optional" default:"jenkins" validate:"omitempty,oneof=jenkins tekton"`
        Type string `form:"type,optional" validate:"omitempty,oneof=task manual_approval"`
        Status int64 `form:"status,optional" default:"-1" validate:"oneof=-1 0 1"`
    }

    ListDevopsStepTemplateResponse {
        Items []DevopsStepTemplate `json:"items"`
        Total uint64 `json:"total"`
    }

    TektonStepImageItem {
        Id string `json:"id"`
        Name string `json:"name"`
        Code string `json:"code"`
        Image string `json:"image"`
        ImageType string `json:"imageType"`
        ParamName string `json:"paramName"`
    }

    ListTektonStepImageRequest {
        Page uint64 `form:"page,optional" default:"1" validate:"required,min=1"`
        PageSize uint64 `form:"pageSize,optional" default:"50" validate:"required,min=1,max=200"`
        Name string `form:"name,optional" validate:"omitempty,max=128"`
        Code string `form:"code,optional" validate:"omitempty,max=64"`
        CategoryId string `form:"categoryId,optional" validate:"omitempty"`
        Status int64 `form:"status,optional" default:"-1" validate:"oneof=-1 0 1"`
    }

    ListTektonStepImageResponse {
        Items []TektonStepImageItem `json:"items"`
        Total uint64 `json:"total"`
    }

    UpdateTektonStepImageItem {
        Id string `json:"id" validate:"required"`
        Image string `json:"image,optional"`
        NewImage string `json:"newImage" validate:"required,min=1"`
        ImageType string `json:"imageType" validate:"required,oneof=image param"`
        ParamName string `json:"paramName,optional" validate:"omitempty,max=128"`
    }

    BatchUpdateTektonStepImageRequest {
        Items []UpdateTektonStepImageItem `json:"items" validate:"required,min=1,dive"`
    }

    BatchUpdateTektonStepImageResponse {
        Total uint64 `json:"total"`
        Updated uint64 `json:"updated"`
    }

    PipelineTemplateStep {
        Id string `json:"id"`
        StepId string `json:"stepId" validate:"required"`
        StepCode string `json:"stepCode,optional" validate:"omitempty,max=128"`
        StepName string `json:"stepName,optional" validate:"omitempty,max=128"`
        NodeName string `json:"nodeName,optional" validate:"omitempty,max=128"`
        ContainerName string `json:"containerName,optional" validate:"omitempty,max=128"`
        StepType string `json:"stepType,optional" validate:"omitempty,oneof=task manual_approval"`
        Icon string `json:"icon,optional" validate:"omitempty,max=128"`
        IconColor string `json:"iconColor,optional" validate:"omitempty,max=32"`
        ParentNodeId string `json:"parentNodeId,optional" validate:"omitempty,max=128"`
        BranchType string `json:"branchType,optional" validate:"omitempty,oneof=next parallel"`
        SortOrder int64 `json:"sortOrder,optional" default:"0" validate:"gte=0"`
        Enabled bool `json:"enabled,optional"`
        X int64 `json:"x,optional"`
        Y int64 `json:"y,optional"`
        ParamValues string `json:"paramValues,optional" validate:"omitempty"`
        ArtifactConfig StepArtifactConfig `json:"artifactConfig,optional"`
    }

    DevopsPipelineTemplate {
        Id string `json:"id"`
        Name string `json:"name"`
        Code string `json:"code"`
        Icon string `json:"icon"`
        IconColor string `json:"iconColor"`
        Description string `json:"description"`
        Scope string `json:"scope"`
        ProjectId string `json:"projectId"`
        EngineType string `json:"engineType"`
        Steps []PipelineTemplateStep `json:"steps"`
        TektonDagConfig string `json:"tektonDagConfig"`
        TektonRunPolicy string `json:"tektonRunPolicy"`
        TektonTriggerConfig string `json:"tektonTriggerConfig"`
        TektonPrunerPolicyRef string `json:"tektonPrunerPolicyRef"`
        TektonPipelineYamlSnapshot string `json:"tektonPipelineYamlSnapshot"`
        Status int64 `json:"status"`
        CreatedBy string `json:"createdBy"`
        UpdatedBy string `json:"updatedBy"`
        CreatedAt int64 `json:"createdAt"`
        UpdatedAt int64 `json:"updatedAt"`
    }

    CreateDevopsPipelineTemplateRequest {
        Name string `json:"name" validate:"required,min=1,max=128"`
        Code string `json:"code" validate:"required,min=2,max=64"`
        Icon string `json:"icon,optional" validate:"omitempty,max=128"`
        IconColor string `json:"iconColor,optional" validate:"omitempty,max=32"`
        Description string `json:"description,optional" validate:"omitempty,max=512"`
        Scope string `json:"scope,optional" default:"system" validate:"oneof=system project"`
        ProjectId string `json:"projectId,optional" validate:"omitempty"`
        EngineType string `json:"engineType,optional" default:"jenkins" validate:"oneof=jenkins tekton"`
        Steps []PipelineTemplateStep `json:"steps,optional"`
        TektonDagConfig string `json:"tektonDagConfig,optional" validate:"omitempty"`
        TektonRunPolicy string `json:"tektonRunPolicy,optional" validate:"omitempty"`
        TektonTriggerConfig string `json:"tektonTriggerConfig,optional" validate:"omitempty"`
        TektonPrunerPolicyRef string `json:"tektonPrunerPolicyRef,optional" validate:"omitempty"`
        TektonPipelineYamlSnapshot string `json:"tektonPipelineYamlSnapshot,optional" validate:"omitempty"`
        Status int64 `json:"status,optional" default:"1" validate:"oneof=0 1"`
    }

    UpdateDevopsPipelineTemplateRequest {
        Id string `path:"id" validate:"required"`
        Name string `json:"name" validate:"required,min=1,max=128"`
        Icon string `json:"icon,optional" validate:"omitempty,max=128"`
        IconColor string `json:"iconColor,optional" validate:"omitempty,max=32"`
        Description string `json:"description,optional" validate:"omitempty,max=512"`
        Scope string `json:"scope,optional" default:"system" validate:"oneof=system project"`
        ProjectId string `json:"projectId,optional" validate:"omitempty"`
        EngineType string `json:"engineType,optional" default:"jenkins" validate:"oneof=jenkins tekton"`
        Steps []PipelineTemplateStep `json:"steps,optional"`
        TektonDagConfig string `json:"tektonDagConfig,optional" validate:"omitempty"`
        TektonRunPolicy string `json:"tektonRunPolicy,optional" validate:"omitempty"`
        TektonTriggerConfig string `json:"tektonTriggerConfig,optional" validate:"omitempty"`
        TektonPrunerPolicyRef string `json:"tektonPrunerPolicyRef,optional" validate:"omitempty"`
        TektonPipelineYamlSnapshot string `json:"tektonPipelineYamlSnapshot,optional" validate:"omitempty"`
        Status int64 `json:"status,optional" default:"1" validate:"oneof=0 1"`
    }

    SaveDevopsPipelineTemplateStepsRequest {
        Id string `path:"id" validate:"required"`
        Steps []PipelineTemplateStep `json:"steps,optional"`
    }

    ListDevopsPipelineTemplateRequest {
        Page uint64 `form:"page,optional" default:"1" validate:"required,min=1"`
        PageSize uint64 `form:"pageSize,optional" default:"12" validate:"required,min=1,max=200"`
        Name string `form:"name,optional" validate:"omitempty,max=128"`
        Code string `form:"code,optional" validate:"omitempty,max=64"`
        Scope string `form:"scope,optional" validate:"omitempty,oneof=system project"`
        ProjectId string `form:"projectId,optional" validate:"omitempty"`
        EngineType string `form:"engineType,optional" validate:"omitempty,oneof=jenkins tekton"`
        Status int64 `form:"status,optional" default:"-1" validate:"oneof=-1 0 1"`
    }

    ListDevopsPipelineTemplateResponse {
        Items []DevopsPipelineTemplate `json:"items"`
        Total uint64 `json:"total"`
    }

    PipelinePreviewResponse {
        Pipeline string `json:"pipeline"`
    }

    TektonRuntimeResource {
        Name string `json:"name"`
        Namespace string `json:"namespace"`
        Kind string `json:"kind"`
        ApiVersion string `json:"apiVersion"`
        Description string `json:"description"`
        Params []string `json:"params"`
        Workspaces []string `json:"workspaces"`
        Results []string `json:"results"`
        Provisioner string `json:"provisioner"`
        ReclaimPolicy string `json:"reclaimPolicy"`
        VolumeBindingMode string `json:"volumeBindingMode"`
        AllowVolumeExpansion bool `json:"allowVolumeExpansion"`
        Secrets []string `json:"secrets"`
        ImagePullSecrets []string `json:"imagePullSecrets"`
        CreatedAt int64 `json:"createdAt"`
        Yaml string `json:"yaml"`
        Keys []string `json:"keys"`
    }

    ListTektonRuntimeResourceRequest {
        ResourceType string `form:"resourceType" validate:"required,oneof=task clusterTask serviceAccount storageClass configMap"`
        ProjectId string `form:"projectId" validate:"required"`
        SystemId string `form:"systemId,optional" validate:"omitempty"`
        EnvironmentId string `form:"environmentId,optional" validate:"omitempty"`
        BuildChannelBindingId string `form:"buildChannelBindingId" validate:"required"`
        Keyword string `form:"keyword,optional" validate:"omitempty,max=128"`
    }

    ListTektonRuntimeResourceResponse {
        Items []TektonRuntimeResource `json:"items"`
        Total uint64 `json:"total"`
    }

    PipelineTemplateVariable {
        StepId string `json:"stepId"`
        StepNodeId string `json:"stepNodeId"`
        StepCode string `json:"stepCode"`
        StepName string `json:"stepName"`
        Name string `json:"name"`
        Code string `json:"code"`
        SourceCode string `json:"sourceCode"`
        ParamType string `json:"paramType"`
        Mode string `json:"mode"`
        DefaultValue string `json:"defaultValue"`
        CurrentValue string `json:"currentValue"`
        Required bool `json:"required"`
        Readonly bool `json:"readonly"`
        Description string `json:"description"`
        SortOrder int64 `json:"sortOrder"`
        RuntimeMode string `json:"runtimeMode"`
        RuntimeConfig bool `json:"runtimeConfig"`
        Config StepParamConfig `json:"config"`
    }

    PipelineTemplateVariablesResponse {
        Items []PipelineTemplateVariable `json:"items"`
        Total uint64 `json:"total"`
    }

    CredentialTypeOption {
        CredentialType string `json:"credentialType"`
        Name string `json:"name"`
        MappingFields []string `json:"mappingFields"`
        DefaultMappingField string `json:"defaultMappingField"`
    }

    CredentialTypeOptionsResponse {
        Items []CredentialTypeOption `json:"items"`
    }

    ListJenkinsCredentialSyncRequest {
        ProjectId string `form:"projectId" validate:"required"`
        BuildChannelBindingId string `form:"buildChannelBindingId" validate:"required"`
        Page uint64 `form:"page,optional" default:"1" validate:"required,min=1"`
        PageSize uint64 `form:"pageSize,optional" default:"20" validate:"required,min=1,max=200"`
    }

    JenkinsCredentialSyncRecord {
        CredentialId string `json:"credentialId"`
        CredentialName string `json:"credentialName"`
        CredentialCode string `json:"credentialCode"`
        CredentialType string `json:"credentialType"`
        JenkinsCredentialId string `json:"jenkinsCredentialId"`
        SyncStatus string `json:"syncStatus"`
        SyncMessage string `json:"syncMessage"`
        LastSyncAt int64 `json:"lastSyncAt"`
        ReferenceCount int64 `json:"referenceCount"`
    }

    ListJenkinsCredentialSyncResponse {
        Items []JenkinsCredentialSyncRecord `json:"items"`
        Total uint64 `json:"total"`
    }

    JenkinsCredentialReferenceRequest {
        ProjectId string `form:"projectId" validate:"required"`
        BuildChannelBindingId string `form:"buildChannelBindingId" validate:"required"`
        CredentialId string `form:"credentialId" validate:"required"`
    }

    JenkinsCredentialReference {
        PipelineId string `json:"pipelineId"`
        PipelineName string `json:"pipelineName"`
        PipelineCode string `json:"pipelineCode"`
        ParamCode string `json:"paramCode"`
        ParamName string `json:"paramName"`
        ReferenceType string `json:"referenceType"`
    }

    JenkinsCredentialReferenceResponse {
        Items []JenkinsCredentialReference `json:"items"`
        Total uint64 `json:"total"`
    }

    DeleteJenkinsCredentialSyncRequest {
        ProjectId string `form:"projectId" validate:"required"`
        BuildChannelBindingId string `form:"buildChannelBindingId" validate:"required"`
        CredentialId string `form:"credentialId" validate:"required"`
    }

    ChannelGroupOption {
        Code string `json:"code"`
        Name string `json:"name"`
    }

    ChannelGroupOptionsResponse {
        Items []ChannelGroupOption `json:"items"`
    }

    ChannelMappingFieldOptionsRequest {
        ChannelGroupCode string `form:"channelGroupCode,optional" validate:"omitempty,max=64"`
        ChannelType      string `form:"channelType,optional" validate:"omitempty,max=64"`
        ChannelTypeId    string `form:"channelTypeId,optional" validate:"omitempty,max=64"`
    }

    ChannelMappingFieldOption {
        GroupCode string `json:"groupCode,optional"`
        Field string `json:"field"`
        Name string `json:"name"`
        Kind string `json:"kind"`
        UiControl string `json:"uiControl"`
        Provider string `json:"provider"`
        Dependencies []ChannelMappingFieldDependency `json:"dependencies,optional"`
        AllOf []ChannelMappingFieldDependency `json:"allOf,optional"`
        AnyOf []ChannelMappingFieldDependency `json:"anyOf,optional"`
        AllowManualInput bool `json:"allowManualInput,optional"`
        AddressBuilder string `json:"addressBuilder,optional"`
        Required bool `json:"required,optional"`
        ChannelTypes []string `json:"channelTypes,optional"`
        ValueType string `json:"valueType,optional"`
        OutputMode string `json:"outputMode,optional"`
        OutputTemplate string `json:"outputTemplate,optional"`
        CredentialPolicy string `json:"credentialPolicy,optional"`
        FallbackAddressFields []string `json:"fallbackAddressFields,optional"`
        ResolveEndpoint bool `json:"resolveEndpoint,optional"`
        Options []StepParamOption `json:"options,optional"`
        SortOrder int64 `json:"sortOrder,optional"`
    }

    ChannelMappingFieldDependency {
        Field string `json:"field"`
        Source string `json:"source"`
        Name string `json:"name"`
        Required bool `json:"required,optional"`
    }

    ChannelMappingFieldOptionsResponse {
        Items []ChannelMappingFieldOption `json:"items"`
    }
    StepChannelParamMappingItem {
        Id                string `json:"id"`
        ParamType         string `json:"paramType"`
        ParamName         string `json:"paramName"`
        GroupCode         string `json:"groupCode"`
        ChannelTypeFilter string `json:"channelTypeFilter"`
        Description       string `json:"description"`
        SortOrder         int64  `json:"sortOrder"`
        Status            int64  `json:"status"`
        IsSystem          bool   `json:"isSystem"`
    }

    CreateStepChannelParamMappingRequest {
        ParamType         string `json:"paramType" validate:"required,min=2,max=128"`
        ParamName         string `json:"paramName" validate:"required,min=1,max=128"`
        GroupCode         string `json:"groupCode" validate:"required,max=64"`
        ChannelTypeFilter string `json:"channelTypeFilter,optional" validate:"omitempty,max=64"`
        Description       string `json:"description,optional" validate:"omitempty,max=512"`
        SortOrder         int64  `json:"sortOrder,optional" validate:"gte=0"`
        Status            int64  `json:"status,optional" default:"1" validate:"oneof=0 1"`
    }

    UpdateStepChannelParamMappingRequest {
        Id                string `path:"id" validate:"required"`
        ParamName         string `json:"paramName" validate:"required,min=1,max=128"`
        GroupCode         string `json:"groupCode" validate:"required,max=64"`
        ChannelTypeFilter string `json:"channelTypeFilter,optional" validate:"omitempty,max=64"`
        Description       string `json:"description,optional" validate:"omitempty,max=512"`
        SortOrder         int64  `json:"sortOrder,optional" validate:"gte=0"`
        Status            int64  `json:"status,optional" default:"1" validate:"oneof=0 1"`
    }

    StepChannelParamMappingListRequest {
        ParamType string `json:"paramType,optional"`
        GroupCode string `json:"groupCode,optional"`
        Status    int64  `json:"status,optional" default:"-1" validate:"oneof=-1 0 1"`
        Page      int64  `json:"page,optional"`
        PageSize  int64  `json:"pageSize,optional"`
    }

    StepChannelParamMappingListResponse {
        Items []StepChannelParamMappingItem `json:"items"`
        Total int64                         `json:"total"`
