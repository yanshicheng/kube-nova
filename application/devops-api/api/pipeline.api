        PipelineCount int64 `json:"pipelineCount"`
        ChannelCount int64 `json:"channelCount"`
    }

    DevopsPipelineDashboardMetric {
        Id string `json:"id"`
        Name string `json:"name"`
        Code string `json:"code"`
        BuildCount int64 `json:"buildCount"`
        SuccessCount int64 `json:"successCount"`
        FailureCount int64 `json:"failureCount"`
        AbortedCount int64 `json:"abortedCount"`
        TotalDurationSeconds int64 `json:"totalDurationSeconds"`
        SuccessRate float64 `json:"successRate"`
        FailureRate float64 `json:"failureRate"`
        AvgDurationSeconds int64 `json:"avgDurationSeconds"`
        LastRunAt string `json:"lastRunAt"`
    }

    DevopsPipelineDashboardTrend {
        Date string `json:"date"`
        BuildCount int64 `json:"buildCount"`
        SuccessCount int64 `json:"successCount"`
        FailureCount int64 `json:"failureCount"`
        DurationSeconds int64 `json:"durationSeconds"`
    }

    DevopsPipelineDashboardResponse {
        Overview DevopsPipelineDashboardOverview `json:"overview"`
        Trends []DevopsPipelineDashboardTrend `json:"trends"`
        ProjectRanks []DevopsPipelineDashboardMetric `json:"projectRanks"`
        SystemRanks []DevopsPipelineDashboardMetric `json:"systemRanks"`
        PipelineRanks []DevopsPipelineDashboardMetric `json:"pipelineRanks"`
        EnvironmentRanks []DevopsPipelineDashboardMetric `json:"environmentRanks"`
        ChannelRanks []DevopsPipelineDashboardMetric `json:"channelRanks"`
    }
)

@server(
    prefix: /devops/v1
    group: pipeline
    middleware: JWTAuthMiddleware
)
service devops-api {
    @doc "创建步骤分类"
    @handler DevopsStepCategoryCreate
    post /pipeline/category (CreateDevopsStepCategoryRequest) returns (IdResponse)

    @doc "更新步骤分类"
    @handler DevopsStepCategoryUpdate
    put /pipeline/category/:id (UpdateDevopsStepCategoryRequest)

    @doc "删除步骤分类"
    @handler DevopsStepCategoryDelete
    delete /pipeline/category/:id (DefaultStringIdRequest)

    @doc "分页查询步骤分类"
    @handler DevopsStepCategoryList
    get /pipeline/category/list (ListDevopsStepCategoryRequest) returns (ListDevopsStepCategoryResponse)

    @doc "获取步骤分类详情"
    @handler DevopsStepCategoryGet
    get /pipeline/category/:id (DefaultStringIdRequest) returns (DevopsStepCategory)

    @doc "创建 Jenkins 步骤"
    @handler DevopsJenkinsStepCreate
    post /pipeline/jenkins/step (CreateDevopsStepTemplateRequest) returns (IdResponse)

    @doc "更新 Jenkins 步骤"
    @handler DevopsJenkinsStepUpdate
    put /pipeline/jenkins/step/:id (UpdateDevopsStepTemplateRequest)

    @doc "删除 Jenkins 步骤"
    @handler DevopsJenkinsStepDelete
    delete /pipeline/jenkins/step/:id (DefaultStringIdRequest)

    @doc "分页查询 Jenkins 步骤"
    @handler DevopsJenkinsStepList
    get /pipeline/jenkins/step/list (ListDevopsStepTemplateRequest) returns (ListDevopsStepTemplateResponse)

    @doc "获取 Jenkins 步骤详情"
    @handler DevopsJenkinsStepGet
    get /pipeline/jenkins/step/:id (DefaultStringIdRequest) returns (DevopsStepTemplate)

    @doc "更新 Jenkins 步骤状态"
    @handler DevopsJenkinsStepStatus
    put /pipeline/jenkins/step/:id/status (UpdateStatusRequest)

    @doc "创建 Tekton 步骤"
    @handler DevopsTektonStepCreate
    post /pipeline/tekton/step (CreateDevopsStepTemplateRequest) returns (IdResponse)

    @doc "更新 Tekton 步骤"
    @handler DevopsTektonStepUpdate
    put /pipeline/tekton/step/:id (UpdateDevopsStepTemplateRequest)

    @doc "删除 Tekton 步骤"
    @handler DevopsTektonStepDelete
    delete /pipeline/tekton/step/:id (DefaultStringIdRequest)

    @doc "分页查询 Tekton 步骤"
    @handler DevopsTektonStepList
    get /pipeline/tekton/step/list (ListDevopsStepTemplateRequest) returns (ListDevopsStepTemplateResponse)

    @doc "查询 Tekton 步骤镜像"
    @handler DevopsTektonStepImageList
    get /pipeline/tekton/step/image/list (ListTektonStepImageRequest) returns (ListTektonStepImageResponse)

    @doc "批量更新 Tekton 步骤镜像"
    @handler DevopsTektonStepImageBatchUpdate
    put /pipeline/tekton/step/image/batch (BatchUpdateTektonStepImageRequest) returns (BatchUpdateTektonStepImageResponse)

    @doc "获取 Tekton 步骤详情"
    @handler DevopsTektonStepGet
    get /pipeline/tekton/step/:id (DefaultStringIdRequest) returns (DevopsStepTemplate)

    @doc "更新 Tekton 步骤状态"
    @handler DevopsTektonStepStatus
    put /pipeline/tekton/step/:id/status (UpdateStatusRequest)

    @doc "创建流水线模板"
    @handler DevopsPipelineTemplateCreate
    post /pipeline/template (CreateDevopsPipelineTemplateRequest) returns (IdResponse)

    @doc "更新流水线模板"
    @handler DevopsPipelineTemplateUpdate
    put /pipeline/template/:id (UpdateDevopsPipelineTemplateRequest)

    @doc "删除流水线模板"
    @handler DevopsPipelineTemplateDelete
    delete /pipeline/template/:id (DefaultStringIdRequest)

    @doc "分页查询流水线模板"
    @handler DevopsPipelineTemplateList
    get /pipeline/template/list (ListDevopsPipelineTemplateRequest) returns (ListDevopsPipelineTemplateResponse)

    @doc "获取流水线模板详情"
    @handler DevopsPipelineTemplateGet
    get /pipeline/template/:id (DefaultStringIdRequest) returns (DevopsPipelineTemplate)

    @doc "更新流水线模板状态"
    @handler DevopsPipelineTemplateStatus
    put /pipeline/template/:id/status (UpdateStatusRequest)

    @doc "保存流水线模板步骤编排"
    @handler DevopsPipelineTemplateStepsSave
    put /pipeline/template/:id/steps (SaveDevopsPipelineTemplateStepsRequest)

    @doc "预览 Jenkins Pipeline"
    @handler DevopsPipelineTemplatePreview
    get /pipeline/template/:id/preview (DefaultStringIdRequest) returns (PipelinePreviewResponse)

    @doc "查看流水线模板变量"
    @handler DevopsPipelineTemplateVariables
    get /pipeline/template/:id/variables (DefaultStringIdRequest) returns (PipelineTemplateVariablesResponse)

    @doc "凭证类型选项"
    @handler DevopsCredentialTypeOptions
    get /pipeline/options/credential-types returns (CredentialTypeOptionsResponse)

    @doc "查询 Jenkins 凭证同步记录"
    @handler DevopsJenkinsCredentialSyncList
    get /pipeline/jenkins/credential-sync/list (ListJenkinsCredentialSyncRequest) returns (ListJenkinsCredentialSyncResponse)

    @doc "查询 Jenkins 凭证引用流水线"
    @handler DevopsJenkinsCredentialReferences
    get /pipeline/jenkins/credential-sync/references (JenkinsCredentialReferenceRequest) returns (JenkinsCredentialReferenceResponse)

    @doc "删除 Jenkins 凭证副本"
    @handler DevopsJenkinsCredentialSyncDelete
    delete /pipeline/jenkins/credential-sync (DeleteJenkinsCredentialSyncRequest)

    @doc "渠道分组选项"
    @handler DevopsChannelGroupOptions
    get /pipeline/options/channel-groups returns (ChannelGroupOptionsResponse)

    @doc "渠道映射字段选项"
    @handler DevopsChannelMappingFieldOptions
    get /pipeline/options/channel-mapping-fields (ChannelMappingFieldOptionsRequest) returns (ChannelMappingFieldOptionsResponse)

    @doc "动态参数选项"
    @handler DevopsDynamicParamOptions
    get /pipeline/options/dynamic-params (DynamicParamOptionsRequest) returns (DynamicParamOptionsResponse)

    @doc "创建系统"
    @handler DevopsSystemCreate
    post /project/system (CreateDevopsSystemRequest) returns (IdResponse)

    @doc "更新系统"
    @handler DevopsSystemUpdate
    put /project/system/:id (UpdateDevopsSystemRequest)

    @doc "删除系统"
    @handler DevopsSystemDelete
    delete /project/system/:id (DefaultStringIdRequest)

    @doc "查询系统"
    @handler DevopsSystemList
    get /project/system/list (ListDevopsSystemRequest) returns (ListDevopsSystemResponse)

    @doc "系统详情"
    @handler DevopsSystemGet
    get /project/system/:id (DefaultStringIdRequest) returns (DevopsSystem)

    @doc "创建流水线环境"
    @handler DevopsPipelineEnvironmentCreate
    post /pipeline/environment (CreateDevopsPipelineEnvironmentRequest) returns (IdResponse)

    @doc "更新流水线环境"
    @handler DevopsPipelineEnvironmentUpdate
    put /pipeline/environment/:id (UpdateDevopsPipelineEnvironmentRequest)

    @doc "删除流水线环境"
    @handler DevopsPipelineEnvironmentDelete
    delete /pipeline/environment/:id (DefaultStringIdRequest)

    @doc "查询流水线环境"
    @handler DevopsPipelineEnvironmentList
    get /pipeline/environment/list (ListDevopsPipelineEnvironmentRequest) returns (ListDevopsPipelineEnvironmentResponse)

    @doc "流水线环境详情"
    @handler DevopsPipelineEnvironmentGet
    get /pipeline/environment/:id (DefaultStringIdRequest) returns (DevopsPipelineEnvironment)

    @doc "查询 Jenkins Agent"
    @handler DevopsPipelineJenkinsAgentList
    get /pipeline/options/jenkins-agents (JenkinsAgentListRequest) returns (JenkinsAgentListResponse)

    @doc "创建 Jenkins Agent"
    @handler DevopsJenkinsAgentCreate
    post /pipeline/jenkins-agent (CreateDevopsJenkinsAgentRequest) returns (IdResponse)

    @doc "更新 Jenkins Agent"
    @handler DevopsJenkinsAgentUpdate
    put /pipeline/jenkins-agent/:id (UpdateDevopsJenkinsAgentRequest)

    @doc "删除 Jenkins Agent"
    @handler DevopsJenkinsAgentDelete
    delete /pipeline/jenkins-agent/:id (DefaultStringIdRequest)

    @doc "查询 Jenkins Agent"
    @handler DevopsJenkinsAgentList
    get /pipeline/jenkins-agent/list (ListDevopsJenkinsAgentRequest) returns (ListDevopsJenkinsAgentResponse)

    @doc "Jenkins Agent 详情"
    @handler DevopsJenkinsAgentGet
    get /pipeline/jenkins-agent/:id (DefaultStringIdRequest) returns (DevopsJenkinsAgent)

    @doc "创建流水线"
    @handler DevopsPipelineCreate
    post /pipeline/instance (SaveDevopsPipelineRequest) returns (IdResponse)

    @doc "更新流水线"
    @handler DevopsPipelineUpdate
    put /pipeline/instance/:id (UpdateDevopsPipelineRequest)

    @doc "删除流水线"
    @handler DevopsPipelineDelete
    delete /pipeline/instance/:id (DefaultStringIdRequest)

    @doc "查询流水线"
    @handler DevopsPipelineList
    get /pipeline/instance/list (ListDevopsPipelineRequest) returns (ListDevopsPipelineResponse)

    @doc "流水线详情"
    @handler DevopsPipelineGet
    get /pipeline/instance/:id (DefaultStringIdRequest) returns (DevopsPipeline)

    @doc "预览流水线"
    @handler DevopsPipelinePreview
    get /pipeline/instance/:id/preview (DefaultStringIdRequest) returns (PipelinePreviewResponse)

    @doc "查询 Tekton 运行时资源"
    @handler DevopsTektonRuntimeResourceList
    get /pipeline/tekton/runtime-resource/list (ListTektonRuntimeResourceRequest) returns (ListTektonRuntimeResourceResponse)

    @doc "运行流水线"
    @handler DevopsPipelineRun
    post /pipeline/instance/:id/run (RunDevopsPipelineRequest) returns (IdResponse)

    @doc "停止流水线执行"
    @handler DevopsPipelineRunStop
    post /pipeline/run/:id/stop (DefaultStringIdRequest)

    @doc "删除流水线执行记录"
    @handler DevopsPipelineRunDelete
    delete /pipeline/run/:id (DefaultStringIdRequest)

    @doc "查询流水线执行记录"
    @handler DevopsPipelineRunList
    get /pipeline/run/list (ListDevopsPipelineRunRequest) returns (ListDevopsPipelineRunResponse)

    @doc "查询流水线阶段状态"
    @handler DevopsPipelineRunStageList
    get /pipeline/run/:runId/stage/list (ListDevopsPipelineRunStageRequest) returns (ListDevopsPipelineRunStageResponse)

    @doc "查询流水线日志"
    @handler DevopsPipelineRunLog
    get /pipeline/run/:runId/log (DevopsPipelineRunLogRequest) returns (DevopsPipelineRunLogResponse)

    @doc "查询流水线 YAML 快照"
    @handler DevopsPipelineRunYamlSnapshot
    get /pipeline/run/:runId/yaml-snapshot (DevopsPipelineRunYamlSnapshotRequest) returns (DevopsPipelineRunYamlSnapshotResponse)

    @doc "查询流水线人工确认"
    @handler DevopsPipelineRunInputList
    get /pipeline/run/:id/input/list (ListDevopsPipelineRunInputRequest) returns (ListDevopsPipelineRunInputResponse)

    @doc "继续流水线人工确认"
    @handler DevopsPipelineRunInputProceed
    post /pipeline/run/:id/input/:inputId/proceed (DevopsPipelineRunInputActionRequest)

    @doc "终止流水线人工确认"
    @handler DevopsPipelineRunInputAbort
    post /pipeline/run/:id/input/:inputId/abort (DevopsPipelineRunInputActionRequest)

    @doc "查询流水线运行产物"
    @handler DevopsPipelineRunArtifactList
    get /pipeline/run/:runId/artifact/list (ListDevopsPipelineRunArtifactRequest) returns (ListDevopsPipelineRunArtifactResponse)

    @doc "流水线驾驶舱"
    @handler DevopsPipelineDashboard
    get /pipeline/dashboard (DevopsPipelineDashboardRequest) returns (DevopsPipelineDashboardResponse)

    @doc "查询步骤参数到渠道分组映射"
    @handler DevopsStepChannelParamMappingList
    get /pipeline/options/step-channel-param-mapping (StepChannelParamMappingListRequest) returns (StepChannelParamMappingListResponse)

    @doc "创建步骤参数到渠道分组映射"
    @handler DevopsStepChannelParamMappingCreate
    post /pipeline/options/step-channel-param-mapping (CreateStepChannelParamMappingRequest) returns (IdResponse)

    @doc "更新步骤参数到渠道分组映射"
    @handler DevopsStepChannelParamMappingUpdate
    put /pipeline/options/step-channel-param-mapping/:id (UpdateStepChannelParamMappingRequest)

    @doc "删除步骤参数到渠道分组映射"
    @handler DevopsStepChannelParamMappingDelete
    delete /pipeline/options/step-channel-param-mapping/:id (DefaultStringIdRequest)
}
